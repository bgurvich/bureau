# ============================================================================
# Secretaire — environment template
# Copy to .env, generate a key (php artisan key:generate), fill in the
# credentials you need. Unset OAuth providers disappear from the UI
# automatically; you don't need to set keys you won't use.
# ============================================================================

# --- Core app -----------------------------------------------------------------
APP_NAME=Secretaire
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production: APP_URL=https://secretaire.aurnata.com

# Rotate APP_KEY safely: set new key in APP_KEY, move old key(s) here
# (comma-separated). Decryption walks them in order. Re-encrypt on save.
# APP_PREVIOUS_KEYS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# --- Logging -----------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Slack channel for the 'slack' log channel — when LOG_CHANNEL=slack (or the
# stack includes it), errors post to this incoming webhook.
# LOG_SLACK_WEBHOOK_URL=

# --- Database ----------------------------------------------------------------
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=secretaire
DB_USERNAME=secretaire
DB_PASSWORD=

# --- Session ----------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# SESSION_DOMAIN must match APP_URL's domain (or stay unset in dev).
# Setting it wrong is the #1 cause of "Invalid OAuth state" on callback.
SESSION_DOMAIN=null

# --- Broadcast / filesystem / queue / cache ---------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# --- Redis -------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Isolate logical Redis DBs per role so `redis-cli flushdb` on the cache
# doesn't nuke sessions or queued jobs as a side effect.
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3
REDIS_QUEUE_CONNECTION=queue

# --- Outbound mail -----------------------------------------------------------
# MAIL_MAILER=log is safe for local — messages go into storage/logs/laravel.log.
# Switch to postmark / ses / smtp for production; docs/ops/outbound-email.md.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Postmark outbound — required when MAIL_MAILER=postmark.
# Create a server in Postmark, copy the server API token. The broadcast
# stream id defaults to "outbound"; override for an "announcements"
# stream if you split transactional + marketing.
# POSTMARK_API_KEY=
# POSTMARK_MESSAGE_STREAM_ID=outbound

# Resend outbound — required when MAIL_MAILER=resend.
# RESEND_API_KEY=

# --- Off-site backup (S3 / B2 / DO Spaces) -----------------------------------
# Setting AWS_BUCKET flips backup:run into writing to both the local disk
# AND this remote one (see config/backup.php).
# For Backblaze B2: AWS_ENDPOINT=https://s3.<region>.backblazeb2.com
# + AWS_USE_PATH_STYLE_ENDPOINT=true.
# Full setup in docs/integrations/auth-credentials.md.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Second-layer AES-256 encryption inside the backup zip. MUST be set when
# AWS_BUCKET is set — otherwise a stolen bucket credential alone can read
# every receipt, statement, and document in the archive. Local-only
# deployments can leave this blank (disk encryption is your only layer).
BACKUP_ARCHIVE_PASSWORD=

# --- Vite -------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# --- LM Studio (local LLM for OCR Tier 2) ------------------------------------
# Local-LLM structured extraction from receipts/bills. Hardware-gated —
# leave disabled until the new GPU is in.
# When running Secretaire in WSL2 and LM Studio on the Windows host, point
# BASE_URL at the Windows host IP (ip route show default), not localhost.
# Enable "Serve on Local Network" in LM Studio so the listener binds 0.0.0.0.
LM_STUDIO_ENABLED=false
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen2.5-coder-7b-instruct
LM_STUDIO_TIMEOUT=120

# --- Postmark inbound webhook -----------------------------------------------
# Basic-auth creds embedded in the webhook URL configured in Postmark's
# server settings (https://user:pass@host/webhooks/postmark/inbound).
# Leave empty in local dev to skip auth.
POSTMARK_WEBHOOK_USER=
POSTMARK_WEBHOOK_PASSWORD=

# --- Social login (Laravel Socialite) ---------------------------------------
# Any provider left blank stays hidden on the login page. Google also
# serves the Gmail inbound integration (same OAuth app — see
# docs/integrations/connect-gmail-calendar.md).
# Default redirect URI: APP_URL + /auth/<provider>/callback
# Override REDIRECT_URL per provider only if your deployment sits behind
# a non-canonical host (e.g. dev tunnel, HTTPS-termination proxy).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URL=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URL=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# MICROSOFT_REDIRECT_URL=
# APPLE_CLIENT_ID is the Services ID (e.g. "homes.secretaire.signin"),
# APPLE_CLIENT_SECRET is a signed JWT that expires every ~6 months. Full
# generation recipe in docs/integrations/auth-credentials.md#apple.
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
# APPLE_REDIRECT_URL=

# --- WebAuthn (passkeys) ----------------------------------------------------
# WEBAUTHN_ID is the relying-party domain the browser binds passkeys to
# (bare host, no scheme, no port). For apex + subdomain coverage set it
# to the apex. WEBAUTHN_NAME falls back to APP_NAME if blank.
# WEBAUTHN_ORIGINS is a comma-separated allowlist of fully-qualified
# origins (https://host:port) that can authenticate; leaving unset means
# "APP_URL only" which is usually right.
# WEBAUTHN_ID=secretaire.aurnata.com
# WEBAUTHN_NAME=Secretaire
# WEBAUTHN_ORIGINS=https://secretaire.aurnata.com

# --- Fastmail (JMAP inbound) ------------------------------------------------
# Optional prefill for `artisan integrations:connect-fastmail` so deploy
# scripts can provision without tty. Generate at fastmail.com → Settings
# → Password & Security → API tokens. Scope: Mail (read). The command
# writes the token (encrypted) onto the integrations row once you run
# it; this env var is just the seed.
# FASTMAIL_API_TOKEN=

# --- PayPal REST API --------------------------------------------------------
# Provisioned per-integration via `artisan integrations:connect-paypal`
# (client_id / client_secret stored encrypted on integrations.credentials).
# Set PAYPAL_VERIFY_WEBHOOK_SIGNATURE=false in local dev if you don't have
# a registered PayPal webhook yet; always true in production.
PAYPAL_VERIFY_WEBHOOK_SIGNATURE=true

# --- Seed defaults (DatabaseSeeder) -----------------------------------------
# Consumed on first `php artisan db:seed` to create the owner user.
# Safe to leave blank; secretaire defaults to
# owner@secretaire.aurnata.com / change-me if unset. Edit these BEFORE
# first run on a production deploy.
SEED_OWNER_EMAIL=
SEED_OWNER_NAME=
SEED_OWNER_PASSWORD=
