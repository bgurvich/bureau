APP_NAME=Secretaire
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production: APP_URL=https://secretaire.aurnata.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=secretaire
DB_USERNAME=secretaire
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Isolate logical Redis DBs per role so `redis-cli flushdb` on the cache
# doesn't nuke sessions or queued jobs as a side effect.
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3
REDIS_QUEUE_CONNECTION=queue

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Off-site backup destination — S3, Backblaze B2, DO Spaces, or any
# S3-compatible endpoint. Setting AWS_BUCKET flips backup:run into
# writing to both the local disk AND this remote one (see config/backup.php).
# For B2: AWS_ENDPOINT=https://s3.<region>.backblazeb2.com + AWS_USE_PATH_STYLE_ENDPOINT=true.
# Full setup in docs/integrations/auth-credentials.md.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Second-layer AES-256 encryption inside the backup zip. MUST be set when
# AWS_BUCKET is set — otherwise a stolen bucket credential alone can read
# every receipt, statement, and document in the archive. Local-only
# deployments can leave this blank (disk encryption is your only layer).
BACKUP_ARCHIVE_PASSWORD=

VITE_APP_NAME="${APP_NAME}"

# LM Studio — local LLM for OCR structured extraction (Tier 2).
# When running Secretaire in WSL2 and LM Studio on the Windows host, point BASE_URL
# at the Windows host IP (from `ip route show default`), not localhost. Enable
# "Serve on Local Network" in LM Studio so the listener binds 0.0.0.0.
LM_STUDIO_ENABLED=false
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen2.5-coder-7b-instruct
LM_STUDIO_TIMEOUT=120

# Postmark inbound webhook — basic-auth creds embedded in the URL configured
# in Postmark's server settings (https://user:pass@host/webhooks/postmark/inbound).
# Leave empty in local dev to skip auth.
POSTMARK_WEBHOOK_USER=
POSTMARK_WEBHOOK_PASSWORD=

# Social login (Laravel Socialite) — any provider left blank stays hidden.
# Google also serves the Gmail inbound integration (same OAuth app).
# Redirect URI for login: APP_URL + /auth/<provider>/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# PayPal REST API — provisioned per-integration via `artisan integrations:connect-paypal`
# (client_id / client_secret stored encrypted on integrations.credentials).
# Set PAYPAL_VERIFY_WEBHOOK_SIGNATURE=false in local dev if you don't have a
# registered PayPal webhook yet; always true in production.
PAYPAL_VERIFY_WEBHOOK_SIGNATURE=true

# Seed defaults — consumed by DatabaseSeeder to create the initial owner
# user on a fresh install. Safe to leave blank; secretaire defaults to
# owner@secretaire.aurnata.com / change-me if unset. Edit these BEFORE
# first run on a production deploy.
SEED_OWNER_EMAIL=
SEED_OWNER_NAME=
SEED_OWNER_PASSWORD=
